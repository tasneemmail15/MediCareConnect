@model MediCareConnect.Models.Medication

@{
    ViewData["Title"] = "Delete Medication";
}

<h1>Delete Medication</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>
        <dt class="col-sm-2">Dosage</dt>
        <dd class="col-sm-10">@Model.Dosage</dd>
        <dt class="col-sm-2">Frequency</dt>
        <dd class="col-sm-10">@Model.Frequency</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>

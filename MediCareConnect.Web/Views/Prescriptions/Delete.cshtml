@model MediCareConnect.Models.Prescription

@{
    ViewData["Title"] = "Delete Prescription";
}

<h1>Delete Prescription</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Patient</dt>
        <dd class="col-sm-10">@Model.Patient.Name</dd>
        <dt class="col-sm-2">Doctor</dt>
        <dd class="col-sm-10">@Model.Doctor.Name</dd>
        <dt class="col-sm-2">Medication</dt>
        <dd class="col-sm-10">@Model.Medication.Name</dd>
        <dt class="col-sm-2">Diagnosis</dt>
        <dd class="col-sm-10">@Model.Diagnosis.Condition</dd>
        <dt class="col-sm-2">Prescription Date</dt>
        <dd class="col-sm-10">@Model.PrescriptionDate.ToShortDateString()</dd>
        <dt class="col-sm-2">End Date</dt>
        <dd class="col-sm-10">@Model.EndDate?.ToShortDateString()</dd>
        <dt class="col-sm-2">Instructions</dt>
        <dd class="col-sm-10">@Model.Instructions</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
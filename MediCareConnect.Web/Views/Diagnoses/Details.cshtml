@model MediCareConnect.Models.Diagnosis

@{
    ViewData["Title"] = "Diagnosis Details";
}

<h1>Diagnosis Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Patient</dt>
        <dd class="col-sm-10">@Model.Patient.Name</dd>
        <dt class="col-sm-2">Doctor</dt>
        <dd class="col-sm-10">@Model.Doctor.Name</dd>
        <dt class="col-sm-2">Diagnosis Date</dt>
        <dd class="col-sm-10">@Model.DiagnosisDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Condition</dt>
        <dd class="col-sm-10">@Model.Condition</dd>
        <dt class="col-sm-2">Notes</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
    </dl>
</div>

<h4>Prescriptions</h4>
<table class="table">
    <thead>
        <tr>
            <th>Medication</th>
            <th>Prescription Date</th>
            <th>End Date</th>
            <th>Instructions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var prescription in Model.Prescriptions)
        {
            <tr>
                <td>@prescription.Medication.Name</td>
                <td>@prescription.PrescriptionDate.ToShortDateString()</td>
                <td>@(prescription.EndDate?.ToShortDateString() ?? "N/A")</td>
                <td>@prescription.Instructions</td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
@model MediCareConnect.Models.Diagnosis

@{
    ViewData["Title"] = "Delete Diagnosis";
}

<h1>Delete Diagnosis</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Patient</dt>
        <dd class="col-sm-10">@Model.Patient.Name</dd>
        <dt class="col-sm-2">Doctor</dt>
        <dd class="col-sm-10">@Model.Doctor.Name</dd>
        <dt class="col-sm-2">Diagnosis Date</dt>
        <dd class="col-sm-10">@Model.DiagnosisDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Condition</dt>
        <dd class="col-sm-10">@Model.Condition</dd>
        <dt class="col-sm-2">Notes</dt>
        <dd class="col-sm-10">@Model.Notes</dd>
    </dl>
</div>

<form asp-action="DeleteConfirmed">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" /> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
@model IEnumerable<MediCareConnect.Models.Patient>

@{
    ViewData["Title"] = "Patients";
}

<h1>Patients</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Add Patient</a>
</div>

<form asp-action="Index" method="get" class="form-inline mb-3">
    <div class="form-group">
        <input type="text" name="searchString" class="form-control" placeholder="Search by name" value="@ViewData["CurrentFilter"]" />
        <button type="submit" class="btn btn-secondary ml-2">Search</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Phone Number</th>
            <th>Email</th>
            <th>Appointments</th>
            <th>Diagnoses</th>
            <th>Prescriptions</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var patient in Model)
        {
            <tr>
                <td>@patient.Name</td>
                <td>@patient.PhoneNumber</td>
                <td>@patient.Email</td>
                <td>
                    <ul>
                        @foreach (var appointment in patient.Appointments)
                        {
                            <li>@appointment.AppointmentDate.ToString("yyyy-MM-dd") with @appointment.Doctor?.Name</li>
                        }
                    </ul>
                </td>
                <td>
                    <ul>
                        @foreach (var diagnosis in patient.Diagnoses)
                        {
                            <li>@diagnosis.Condition</li>
                        }
                    </ul>
                </td>
                <td>
                    <ul>
                        @foreach (var prescription in patient.Prescriptions)
                        {
                            <li>@prescription.Medication?.Name - @prescription.Instructions</li>
                        }
                    </ul>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@patient.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Delete" asp-route-id="@patient.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
